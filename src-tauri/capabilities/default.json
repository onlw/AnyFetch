{
  "$schema": "https://schema.tauri.app/config/2",
  "identifier": "default",
  "description": "AnyFetch default capabilities",
  "windows": ["main"],
  "permissions": [
    "allow-all-commands",
    "core:default",
    "shell:allow-execute",
    "shell:allow-spawn",
    "shell:allow-kill",
    "dialog:allow-open",
    "dialog:allow-save",
    "fs:allow-read-text-file",
    "fs:allow-write-text-file",
    "fs:allow-read-dir",
    "fs:allow-mkdir",
    "fs:allow-exists",
    "opener:allow-open-url",
    "opener:allow-reveal-item-in-dir"
  ]
}
