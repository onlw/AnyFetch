{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "AnyFetch",
  "version": "0.1.0",
  "identifier": "com.hope.anyfetch",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "AnyFetch",
        "width": 1100,
        "height": 720,
        "minWidth": 800,
        "minHeight": 560,
        "hiddenTitle": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
